# Server Configuration
HOST=0.0.0.0
PORT=5000
DEBUG=false

# YARN Configuration
YARN_RM_HOST=10.1.1.144
YARN_RM_PORT=8088

# Paths Configuration
JOBS_DIR=data/jobs
RESULTS_DIR=data/results
LOG_DIR=logs

# Hadoop Configuration
HADOOP_HOME=/opt/hadoop
HADOOP_CONF_DIR=/opt/hadoop/etc/hadoop
HADOOP_JAR_PATH=hdfs://hadoop-namenode:9820/user/hadoop/jars/hadoop-1.0-SNAPSHOT.jar
HADOOP_MAIN_CLASS=it.unipi.App
HADOOP_INPUT_DIR=github-events-dataset/
HADOOP_OUTPUT_DIR=github-events-output/hadoop/

# Spark Configuration
SPARK_HOME=/opt/spark
SPARK_SCRIPT=hdfs://hadoop-namenode:9820/user/hadoop/scripts/spark/main.py
SPARK_MASTER=yarn
SPARK_DEPLOY_MODE=cluster

# Python Non-Parallel Configuration
PYTHON_NON_PARALLEL_SCRIPT=hdfs://hadoop-namenode:9820/user/hadoop/scripts/python/main.py
PYTHON_EXECUTABLE=python3

# Job Configuration
MAX_CONCURRENT_JOBS=5
JOB_TIMEOUT_SECONDS=3600
JOB_POLL_INTERVAL=10

# Application Configuration
APP_NAME='GitHub Event Aggregation Ranking'
APP_VERSION=1.0.0
SECRET_KEY=your-secret-key-here-change-in-production

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT='%(asctime)s - %(name)s - %(levelname)s - %(message)s'
LOG_FILE=logs/app.log

# HDFS Configuration
HDFS_URL=hdfs://hdfs-namenode:9000
HDFS_USER=hadoop

# YARN Application Configuration
YARN_APPLICATION_QUEUE=default
YARN_APPLICATION_PRIORITY=0
YARN_APPLICATION_TYPE=YARN
YARN_AM_MEMORY=1024
YARN_AM_VCORES=1
YARN_CONTAINER_MEMORY=1024
YARN_CONTAINER_VCORES=1
YARN_MAX_APP_ATTEMPTS=2

